APP_NAME="Rajawali Platform API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:5174
IDENTITY_INVITATION_LIFETIME_HOURS=72
IDENTITY_STEP_UP_LIFETIME_MINUTES=15
IDENTITY_TOTP_WINDOW=1
IDENTITY_RECOVERY_CODE_COUNT=8
IDENTITY_PRIVILEGED_ASSIGNMENT_MAX_DAYS=90
IDENTITY_ERP_TOKEN_LIFETIME_MINUTES=720
IDENTITY_OPS_TOKEN_LIFETIME_MINUTES=1440
IDENTITY_MOBILE_TOKEN_LIFETIME_MINUTES=15
IDENTITY_MOBILE_REFRESH_TOKEN_LIFETIME_DAYS=30
IDENTITY_ERP_IDLE_TIMEOUT_MINUTES=30
IDENTITY_OPS_IDLE_TIMEOUT_MINUTES=120
IDENTITY_MOBILE_IDLE_TIMEOUT_MINUTES=15
IDENTITY_DEFAULT_IDLE_TIMEOUT_MINUTES=30
AUTH_PASSWORD_RESET_EXPIRE=60

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=rajawali_v2
DB_USERNAME=rajawali
DB_PASSWORD=rajawali_local_only

SESSION_DRIVER=redis
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
FILES_MAX_BYTES=20971520
FILES_PENDING_LIFETIME_HOURS=24
FILES_SCAN_DRIVER=clamav
FILES_ALLOW_UNSCANNED=false
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=30
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

IDEMPOTENCY_PROCESSING_TIMEOUT_MINUTES=5
IDEMPOTENCY_RETENTION_HOURS=24
IDEMPOTENCY_MAX_RESPONSE_BYTES=1048576
OUTBOX_MAX_PAYLOAD_BYTES=65536
OUTBOX_BATCH_SIZE=100
OUTBOX_PROCESSING_TIMEOUT_MINUTES=5
OUTBOX_MAX_ATTEMPTS=5
NOTIFICATION_DELIVERY_MAX_ATTEMPTS=5

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@rajawali.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=rajawali
AWS_SECRET_ACCESS_KEY=rajawali_local_only
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=rajawali-v2-local
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://127.0.0.1:9000

VITE_APP_NAME="${APP_NAME}"
