APP_NAME="Rajawali Platform API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:5174
IDENTITY_INVITATION_LIFETIME_HOURS=72
IDENTITY_STEP_UP_LIFETIME_MINUTES=15
IDENTITY_PRIVILEGED_ASSIGNMENT_MAX_DAYS=90
IDENTITY_ERP_TOKEN_LIFETIME_MINUTES=720
IDENTITY_OPS_TOKEN_LIFETIME_MINUTES=1440
IDENTITY_MOBILE_TOKEN_LIFETIME_MINUTES=15

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=rajawali_v2
DB_USERNAME=rajawali
DB_PASSWORD=rajawali_local_only

SESSION_DRIVER=redis
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@rajawali.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=rajawali
AWS_SECRET_ACCESS_KEY=rajawali_local_only
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=rajawali-v2-local
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://127.0.0.1:9000

VITE_APP_NAME="${APP_NAME}"
