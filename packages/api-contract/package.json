{
  "name": "@rajawali/api-contract",
  "private": true,
  "version": "0.17.1",
  "type": "module",
  "scripts": {
    "generate": "openapi-typescript openapi.yaml -o src/generated.ts",
    "check": "npm run generate && git diff --exit-code -- src/generated.ts",
